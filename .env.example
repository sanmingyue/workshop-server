# Discord OAuth2 配置
DISCORD_CLIENT_ID=你的Discord应用ID
DISCORD_CLIENT_SECRET=你的Discord应用密钥

# 允许的 Discord 服务器 ID（逗号分隔，用户必须在其中一个）
DISCORD_GUILD_IDS=1380075940285124724,1134557553011998840

# 管理员 Discord 用户 ID（逗号分隔）
ADMIN_DISCORD_IDS=你的Discord用户ID

# 会话密钥（随便填一串字符）
SESSION_SECRET=smy-workshop-2026-secret-key

# 下载指纹密钥（建议单独设置；不填时会使用 SESSION_SECRET）
FINGERPRINT_SECRET=smy-workshop-fingerprint-secret-key

# 后端服务的完整 URL（Zeabur 部署后填）
BASE_URL=https://你的域名.zeabur.app

# 数据存储路径（Zeabur 持久化磁盘挂载点）
DATA_DIR=/data

# 端口（Zeabur 会自动设置，不需要手动填）
# PORT=3000
